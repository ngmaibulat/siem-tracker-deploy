# mariadb-galera lab env — copy to `.env` in this folder:
#   cp example.env .env
#   chmod 600 .env
#
# This is a manual-QA / exploration lab (3-node Galera cluster + MaxScale),
# not the hardened prod topology — see ../default for that. All DB hostnames
# are hardcoded in docker-compose.yml to internal service names; only
# passwords and a couple of app settings are parameterized here. The
# `maxscale` monitor/router password lives only in maxscale.cnf and
# init/01-init.sh (not here) — see the note in those files.

# --- Optional (all have working defaults) ---

# JWT signing secret. Leave unset to use the wizard-generated one (recommended).
# APP_SECRET=

# APP_URL is fixed to http://localhost:3005 in docker-compose.yml (no
# nginx/TLS in this lab).
TARGET_DATE=2026-12-31

# MariaDB passwords (all three nodes share MARIADB_ROOT_PASSWORD; only node1
# sets MARIADB_PASSWORD via the official image's bootstrap). Defaults match
# the app repo's dev lab exactly, so behavior is unchanged out of the box; set
# your own to harden. Changing these later does NOT update an
# already-initialized mariadb volume.
#   MARIADB_ROOT_PASSWORD — root superuser (healthchecks; also what the
#                           image's SST-safe healthcheck relies on). Default: root_password
#   MARIADB_PASSWORD      — the app's `siem` user. Default: siem_password
# MARIADB_ROOT_PASSWORD=
# MARIADB_PASSWORD=

# Postgres password (FR-42 restore-helper only, not part of the cluster
# topology). Default: postgres_password
# POSTGRES_PASSWORD=

# MailHog web UI (view QA email): http://<host>:8030
# MaxScale GUI/REST: http://<host>:18989 (admin/mariadb, dev-only plain HTTP)
