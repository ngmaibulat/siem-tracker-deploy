# mariadb-galera lab env — copy to `.env` in this folder:
#   cp example.env .env
#   chmod 600 .env
#
# This is a manual-QA / exploration lab (3-node Galera cluster), not the
# hardened prod topology — see ../default for that. All DB hostnames are
# hardcoded in docker-compose.yml to internal service names; only passwords
# and a couple of app settings are parameterized here.

# --- Optional (all have working defaults) ---

# JWT signing secret. Leave unset to use the wizard-generated one (recommended).
# APP_SECRET=

# Public base URL (invite/reset links). Defaults to http://localhost — nginx
# fronts the app on host ports 80/443 (the app publishes no ports); set this
# when serving on a real hostname.
# APP_URL=

TARGET_DATE=2026-12-31

# MariaDB passwords (all three nodes share MARIADB_ROOT_PASSWORD; only node1
# sets MARIADB_PASSWORD via the official image's bootstrap). Defaults match
# the app repo's dev lab exactly, so behavior is unchanged out of the box; set
# your own to harden. Changing these later does NOT update an
# already-initialized mariadb volume.
#   MARIADB_ROOT_PASSWORD — root superuser (healthchecks; also what the
#                           image's SST-safe healthcheck relies on). Default: root_password
#   MARIADB_PASSWORD      — the app's `siem` user. Default: siem_password
# MARIADB_ROOT_PASSWORD=
# MARIADB_PASSWORD=

# Postgres password (FR-42 restore-helper only, not part of the cluster
# topology). Default: postgres_password
# POSTGRES_PASSWORD=

# Shared secret between the app and the external scheduler service (FR-46,
# scheduled report delivery — the `scheduler` compose service). Generate e.g.:
# openssl rand -hex 32. Leave unset to disable: the app's scheduler endpoints
# answer 503, and the scheduler container exits on start (comment the service
# out in docker-compose.yml to stop it respawning). The in-app "Run now"
# trigger at /admin/scheduler still works without it.
# SCHEDULER_TOKEN=

# MinIO root password — backs S3-compatible object storage for the rich-text
# editor's pasted-image uploads (S3_SECRET_ACCESS_KEY, docker-compose.yml).
# Default: siem_minio_password. Changing it later does NOT update an
# already-initialized minio_data volume.
# MINIO_ROOT_PASSWORD=

# No SMTP_URL / MailHog here — this lab has no fake mail catcher. Configure a
# real SMTP server via the Initial Configuration Wizard or /admin/smtp.
