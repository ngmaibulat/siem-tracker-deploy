# MaxScale config for the Galera lab. Mirrors the canonical config used by the
# siem-tracker app repo's containers/mariadb-galera dev lab (configs/maxscale.cnf
# there). The app connects to the readwritesplit listener on 4006
# (mysql://…@maxscale:4006/…); galeramon monitors the three nodes and
# designates one as Master for writes. maxscale.log lands in this lab's own
# data/maxscale-logs via its compose bind mount; the app reads it read-only
# via MAXSCALE_LOG_DIR for the admin log viewer.
#
# The `maxscale` monitor/router password below is a plain hardcoded value
# (this file isn't a docker-compose environment: block, so there's no clean
# way to parameterize it via .env without extra tooling) — fine for a QA/
# exploration lab; change it here directly if you need to.

[maxscale]
threads=auto
admin_host=0.0.0.0
# Dev/QA only: serve the GUI/REST API over plain HTTP on 8989 (admin/mariadb).
admin_secure_gui=false

[node1]
type=server
address=mariadb-node1
port=3306

[node2]
type=server
address=mariadb-node2
port=3306

[node3]
type=server
address=mariadb-node3
port=3306

[Galera-Monitor]
type=monitor
module=galeramon
servers=node1,node2,node3
user=maxscale
password=maxscale_password
monitor_interval=2s

[RW-Split]
type=service
router=readwritesplit
servers=node1,node2,node3
user=maxscale
password=maxscale_password
# Reads may also land on the write node; combined with wsrep_sync_wait=1 on
# the nodes (see galera.cnf) reads are causally safe on any node.
master_accept_reads=true

[RW-Listener]
type=listener
service=RW-Split
port=4006
