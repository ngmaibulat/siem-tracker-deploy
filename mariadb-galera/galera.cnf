# Galera cluster config shared by all three MariaDB nodes below. Mirrors the
# canonical config used by the siem-tracker app repo's containers/mariadb-galera
# dev lab (configs/galera.cnf there). Per-node settings (node name/address,
# error-log file, bootstrap flag) are passed on the command line in
# docker-compose.yml.

[mysqld]
binlog_format=ROW
default_storage_engine=InnoDB
innodb_autoinc_lock_mode=2
character_set_server=utf8mb4
collation_server=utf8mb4_unicode_ci
# Durability tradeoff (crash of a single node loses <=1s of its local
# flushes; the cluster still has the data on the other nodes).
innodb_flush_log_at_trx_commit=2
skip_name_resolve=ON

wsrep_on=ON
wsrep_provider=/usr/lib/galera/libgalera_smm.so
wsrep_cluster_name=siem-galera
wsrep_cluster_address=gcomm://mariadb-node1,mariadb-node2,mariadb-node3
wsrep_sst_method=rsync
# Read causality: a read waits until the node has applied all write-sets seen
# by the cluster at read time, so reads against ANY node (the app talks only
# to node1, but node2/3 are published on host ports for manual QA) never hit
# read-your-writes anomalies. This is the standard Galera answer to
# "create → redirect → read misses the row"; costs some read latency.
wsrep_sync_wait=1
