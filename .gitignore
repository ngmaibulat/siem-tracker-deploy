# Secrets — never commit (this repo is public).
# Real per-lab env (copy example.env → .env in each lab dir and fill in).
.env
default/.env
mariadb-multimaster/.env
mariadb-galera/.env
# Real TLS material for the default lab's nginx (see default/nginx/certs/README.md).
default/nginx/certs/*.pem
default/nginx/certs/*.csr
default/nginx/certs/*.key
# Galera lab log bind mounts — keep the directories (.gitkeep), not their contents.
mariadb-galera/data/mariadb-logs/*
mariadb-galera/data/maxscale-logs/*
!mariadb-galera/data/mariadb-logs/.gitkeep
!mariadb-galera/data/maxscale-logs/.gitkeep
